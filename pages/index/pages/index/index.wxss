.screen {
  min-height: 100vh;
  padding: 32rpx 28rpx 56rpx;
  box-sizing: border-box;
}

.hero {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: flex-start;
  padding: 28rpx 0 32rpx;
}

.eyebrow {
  display: block;
  color: #6d7b59;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
  margin-bottom: 12rpx;
}

.title {
  display: block;
  color: #15191d;
  font-size: 48rpx;
  line-height: 1.12;
  font-weight: 800;
  letter-spacing: 0;
}

.subtitle {
  display: block;
  color: #586069;
  font-size: 27rpx;
  line-height: 1.55;
  margin-top: 18rpx;
  max-width: 480rpx;
}

.price {
  flex: 0 0 156rpx;
  min-height: 132rpx;
  border: 2rpx solid #d8c8a7;
  border-radius: 8rpx;
  background: #fffaf0;
  padding: 18rpx 14rpx;
  box-sizing: border-box;
  text-align: center;
}

.price-value {
  display: block;
  color: #22272e;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 800;
}

.price-label {
  display: block;
  color: #6b5b3f;
  font-size: 21rpx;
  line-height: 1.35;
  margin-top: 8rpx;
}

.panel,
.result-panel,
.sell-panel {
  background: #ffffff;
  border: 2rpx solid #e4dfd4;
  border-radius: 8rpx;
  padding: 28rpx;
  box-sizing: border-box;
  box-shadow: 0 16rpx 40rpx rgba(37, 43, 50, 0.06);
}

.field + .field {
  margin-top: 28rpx;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.label {
  display: block;
  color: #23282f;
  font-size: 27rpx;
  line-height: 1.3;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.counter {
  color: #7a828c;
  font-size: 23rpx;
  margin-bottom: 14rpx;
}

.input,
.textarea {
  width: 100%;
  border: 2rpx solid #d9dee6;
  border-radius: 8rpx;
  background: #fbfcfd;
  color: #1d2329;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input {
  height: 86rpx;
  padding: 0 22rpx;
}

.textarea {
  height: 276rpx;
  padding: 20rpx 22rpx;
  line-height: 1.5;
}

.segments {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.segments.three {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.segment {
  height: 76rpx;
  border-radius: 8rpx;
  border: 2rpx solid #d9dee6;
  background: #fbfcfd;
  color: #46515d;
  font-size: 26rpx;
  line-height: 76rpx;
  padding: 0 10rpx;
}

.segment.active {
  border-color: #496f5d;
  background: #e7f0e8;
  color: #254b39;
  font-weight: 800;
}

.primary {
  width: 100%;
  height: 92rpx;
  margin-top: 32rpx;
  border-radius: 8rpx;
  background: #1f6f56;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 92rpx;
}

.result-panel,
.sell-panel {
  margin-top: 24rpx;
}

.result-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.result-title,
.sell-title {
  color: #1d2329;
  font-size: 30rpx;
  font-weight: 800;
}

.copy {
  width: 112rpx;
  height: 62rpx;
  border: 2rpx solid #1f6f56;
  border-radius: 8rpx;
  background: #ffffff;
  color: #1f6f56;
  font-size: 25rpx;
  line-height: 62rpx;
}

.result-text {
  display: block;
  white-space: pre-wrap;
  color: #2a3138;
  font-size: 27rpx;
  line-height: 1.62;
}

.sell-title {
  display: block;
  margin-bottom: 14rpx;
}

.sell-line {
  display: block;
  color: #59636e;
  font-size: 26rpx;
  line-height: 1.58;
}

.sell-line + .sell-line {
  margin-top: 10rpx;
}
